{
  "name": "@ramarivera/pi-model-guardrails",
  "version": "0.2.1",
  "description": "Deterministic destructive-command guard + inviolable-constraint policy engine and deviation state machine for the Pi coding agent",
  "type": "module",
  "license": "MIT",
  "author": "Ramiro Rivera",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramarivera/pi-model-guardrails.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "tsx --test test/**/*.test.ts",
    "test:e2e": "tsx --test e2e/test/**/*.test.ts",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "coding-agent"
  ],
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "effect": "^3.21.2"
  }
}
